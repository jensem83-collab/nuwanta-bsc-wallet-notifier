# Copy this file to .env and fill in real values.
# .env is git-ignored; .env.example is safe to commit (placeholders only).

# --- Telegram ---
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Numeric chat/group ID. Run `npm run get-chat-id` to discover it.
TELEGRAM_CHAT_ID=your_chat_id_here

# --- BSC data source (Moralis) ---
# Free tier at https://moralis.io — used because BscScan V1 is deprecated
# and Etherscan V2 free tier does not cover BSC.
MORALIS_API_KEY=your_moralis_api_key_here

# --- Wallets being monitored ---
# Comma-separated list of BSC addresses (0x + 40 hex chars each).
# Preferred over the legacy single WALLET_ADDRESS.
WALLET_ADDRESSES=0xFirstWalletHere,0xSecondWalletHere

# Optional positional nicknames — same order as WALLET_ADDRESSES.
# Used as the wallet label in Telegram alerts. Leave blank to use a
# shortened address like "0xABCD...1234".
WALLET_LABELS=Main,Trading

# Legacy single-wallet var. Only used if WALLET_ADDRESSES is unset.
# WALLET_ADDRESS=0xYourWalletAddressHere

# --- Optional: polling + filtering ---
# How often to poll Moralis for new txs, in seconds. Default 60.
# At 30s you may exceed the Moralis free-tier CU budget → HTTP 500s.
POLL_INTERVAL_SEC=60

# Set to "false" to receive every spam/airdrop transfer Moralis flags.
# Defaults to true (spam hidden) when the var is unset.
FILTER_SPAM=true

# --- Legacy (not required) ---
# Kept only for reference; the V1 BscScan API was deprecated in 2025.
# BSCSCAN_API_KEY=your_bscscan_key_here
